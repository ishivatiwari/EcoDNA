# EcoDNA Environment Configuration
# Copy this file to .env and fill in values for local development.

# ── API Configuration ──────────────────────────
# Optional API key for authenticating external service calls.
# Leave blank to run in local/offline mode.
API_KEY=

# ── Server Configuration ───────────────────────
# Port for the uvicorn development server (default: 8080).
PORT=8080

# ── Logging ────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL (default: INFO)
LOG_LEVEL=INFO

# ── Rate Limiting ──────────────────────────────
# Max requests per IP per window (default: 30)
RATE_LIMIT_MAX_REQUESTS=30
# Window duration in seconds (default: 60)
RATE_LIMIT_WINDOW_SECONDS=60
